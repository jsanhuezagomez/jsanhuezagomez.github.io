---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';
const base = import.meta.env.BASE_URL;
const basePath = base.endsWith('/') ? base : `${base}/`;
const posts = (await getCollection('blog', ({ data }) => !data.draft))
  .filter((post) => post.data.category === 'finanzas' || post.data.category === 'calculadoras')
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout title="Finanzas">
  <h1>Finanzas</h1>
  <p>Contenido sobre AFP, ahorro, inversión y planificación financiera personal.</p>
  <div class="card">
    <h3>Calculadora de Cambio AFP</h3>
    <p>Compara escenarios de AFP actual vs destino con comisiones y cuenta alternativa.</p>
    <a href={`${basePath}herramientas/calculadora-afp/index.html`}>Abrir Calculadora de Cambio AFP</a>
  </div>

  <h2>Artículos de Finanzas</h2>
  <div class="grid">
    {posts.map((post) => (
      <article class="card">
        <h3><a href={`${basePath}blog/${post.slug}/`}>{post.data.title}</a></h3>
        <p>{post.data.description}</p>
        <div>
          <span class="badge">{post.data.category}</span>
          <span class="badge">{post.data.pubDate.toLocaleDateString('es-CL')}</span>
        </div>
      </article>
    ))}
  </div>
</BaseLayout>
